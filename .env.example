# Supabase project settings (Project Settings → API).
# Leave both unset to run the site against the bundled static sample data.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Password required to sign in to /admin. Choose a strong, unique value.
ADMIN_PASSWORD=change-me

# Optional: Google Search Console HTML tag verification content.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
