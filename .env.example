# Supabase project settings (Project Settings → API).
# Leave both unset to run the site against the bundled static sample data.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Same project's public URL + anon key (Project Settings → API), used
# client-side for user sign-up/sign-in only. Safe to expose — the anon key
# has no access to app tables (no RLS policies grant it any).
# Leave both unset to hide the Sign In UI (anonymous "interested" tracking
# still works without it).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Password required to sign in to /admin. Choose a strong, unique value.
ADMIN_PASSWORD=change-me

# Optional: shared secret for automated daily imports (POST /api/admin/import
# with `Authorization: Bearer <key>` instead of an admin login). Leave unset
# to disable this path — the admin UI import at /admin/new still works.
INGEST_API_KEY=

# Optional: Google Search Console HTML tag verification content.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
